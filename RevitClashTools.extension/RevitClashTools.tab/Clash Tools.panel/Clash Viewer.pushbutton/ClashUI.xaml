<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Navisworks Clash Viewer" Height="720" Width="960"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding SummaryText}" FontWeight="Bold" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <GroupBox Grid.Row="1" Header="1. Map each source model in the report to a loaded Revit link (or the host), then Resolve" Margin="0,0,0,8">
            <DataGrid Name="ModelsGrid" AutoGenerateColumns="False" Height="120" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Source (from report)" Binding="{Binding SourceFile}" IsReadOnly="True" Width="300"/>
                    <DataGridComboBoxColumn Header="Match to Revit link / host" x:Name="LinkColumn" Width="320"/>
                    <DataGridCheckBoxColumn Header="Isolate link to clash elems" Binding="{Binding Isolate}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="2. Group the resolved clash elements by a parameter, then Build Groups" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="Group by:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Name="GroupByCombo" Width="200" VerticalAlignment="Center"/>
                <TextBlock Text="Custom parameter name:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                <TextBox Name="CustomParamBox" Width="200" VerticalAlignment="Center"/>
                <Button Name="BuildGroupsButton" Content="Build Groups" Width="120" Margin="16,0,0,0" Click="build_groups_click"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="3. Set a color per group (auto-assigned; edit as needed), untick to skip" Margin="0,0,0,8">
            <DataGrid Name="GroupsGrid" AutoGenerateColumns="False" Height="150" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Group value" Binding="{Binding GroupValue}" IsReadOnly="True" Width="380"/>
                    <DataGridTextColumn Header="Elements" Binding="{Binding Count}" IsReadOnly="True" Width="90"/>
                    <DataGridComboBoxColumn Header="Color" x:Name="GroupColorColumn" Width="150"/>
                    <DataGridCheckBoxColumn Header="Include" Binding="{Binding Include}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="Parsed clashes (preview)" Margin="0,0,0,8">
            <DataGrid Name="ClashesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Test" Binding="{Binding TestName}" Width="130"/>
                    <DataGridTextColumn Header="Result" Binding="{Binding ResultName}" Width="90"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="65"/>
                    <DataGridTextColumn Header="Item A" Binding="{Binding NameA}" Width="140"/>
                    <DataGridTextColumn Header="Source A" Binding="{Binding SourceA}" Width="105"/>
                    <DataGridTextColumn Header="A?" Binding="{Binding MatchedA}" Width="60"/>
                    <DataGridTextColumn Header="Item B" Binding="{Binding NameB}" Width="140"/>
                    <DataGridTextColumn Header="Source B" Binding="{Binding SourceB}" Width="105"/>
                    <DataGridTextColumn Header="B?" Binding="{Binding MatchedB}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="InspectButton" Content="Inspect Raw XML" Width="120" Margin="4" Click="inspect_click"/>
            <Button Name="ResolveButton" Content="Resolve Elements" Width="130" Margin="4" Click="resolve_click"/>
            <Button Name="ApplyButton" Content="Apply Colors" Width="120" Margin="4" Click="apply_click"/>
            <Button Name="ResetButton" Content="Reset View" Width="100" Margin="4" Click="reset_click"/>
            <Button Name="CloseButton" Content="Close" Width="80" Margin="4" Click="close_click"/>
        </StackPanel>
    </Grid>
</Window>
