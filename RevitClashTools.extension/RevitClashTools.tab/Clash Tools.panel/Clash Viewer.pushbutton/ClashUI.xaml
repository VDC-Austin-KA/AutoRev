<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Navisworks Clash Viewer" Height="620" Width="900"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding SummaryText}" FontWeight="Bold" Margin="0,0,0,8"/>

        <GroupBox Grid.Row="1" Header="Model assignment (map each source model found in the report to a loaded link, and pick its override color)" Margin="0,0,0,8">
            <DataGrid Name="ModelsGrid" AutoGenerateColumns="False" Height="160" CanUserAddRows="False" ItemsSource="{Binding ModelRows}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Source (from report)" Binding="{Binding SourceFile}" IsReadOnly="True" Width="220"/>
                    <DataGridComboBoxColumn Header="Match to Revit link / host" x:Name="LinkColumn" Width="260"/>
                    <DataGridComboBoxColumn Header="Override Color" x:Name="ColorColumn" Width="150"/>
                    <DataGridCheckBoxColumn Header="Isolate (only clash elems)" Binding="{Binding Isolate}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Parsed clashes (preview)" Margin="0,0,0,8">
            <DataGrid Name="ClashesGrid" AutoGenerateColumns="False" ItemsSource="{Binding ClashRows}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Test" Binding="{Binding TestName}" Width="140"/>
                    <DataGridTextColumn Header="Result" Binding="{Binding ResultName}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                    <DataGridTextColumn Header="Item A" Binding="{Binding NameA}" Width="150"/>
                    <DataGridTextColumn Header="Source A" Binding="{Binding SourceA}" Width="110"/>
                    <DataGridTextColumn Header="Matched A" Binding="{Binding MatchedA}" Width="70"/>
                    <DataGridTextColumn Header="Item B" Binding="{Binding NameB}" Width="150"/>
                    <DataGridTextColumn Header="Source B" Binding="{Binding SourceB}" Width="110"/>
                    <DataGridTextColumn Header="Matched B" Binding="{Binding MatchedB}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="InspectButton" Content="Inspect Raw XML" Width="120" Margin="4" Click="inspect_click"/>
            <Button Name="ResolveButton" Content="Resolve GUIDs" Width="120" Margin="4" Click="resolve_click"/>
            <Button Name="ApplyButton" Content="Apply Overrides" Width="120" Margin="4" Click="apply_click"/>
            <Button Name="ResetButton" Content="Reset View" Width="100" Margin="4" Click="reset_click"/>
            <Button Name="CloseButton" Content="Close" Width="80" Margin="4" Click="close_click"/>
        </StackPanel>
    </Grid>
</Window>
